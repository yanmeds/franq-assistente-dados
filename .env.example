# Provedor de LLM: google (padrão), openai ou anthropic
LLM_PROVIDER=google

# Modelo. Tier gratuito: gemini-2.5-flash (recomendado) ou gemini-2.5-flash-lite (mais barato)
MODEL_NAME=gemini-2.5-flash

# Chave de API do provedor escolhido (preencha apenas a que for usar)
GOOGLE_API_KEY=sua_chave_aqui
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Caminho do banco SQLite
DB_PATH=data/clientes_completo.db

# Parâmetros do agente
TEMPERATURE=0
MAX_SQL_ATTEMPTS=3
MAX_ROWS_TO_LLM=50

# Tentativas em erros temporários de rate limit
MAX_LLM_RETRIES=4
